{
  "name": "defyance-songs-website",
  "version": "1.0.0",
  "description": "Band management app",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run serve\" \"npm run dev:electron\"",
    "dev:electron": "npm run build:main && cross-env NODE_ENV=development wait-on http://localhost:3002 && electron .",
    "build": "npm run build:react && npm run build:electron",
    "build:main": "tsc -p tsconfig.json",
    "build:react": "webpack --mode production",
    "build:electron": "npm run build:main && electron-builder",
    "serve": "webpack serve --mode development"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "html-webpack-plugin": "^5.6.7",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.5",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "dotenv": "^17.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sqlite3": "^6.0.1"
  }
}
