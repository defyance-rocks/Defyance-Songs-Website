{
  "name": "defyance-songs-website",
  "version": "1.0.0",
  "description": "Band management app",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "concurrently \"npm run serve\" \"npm run dev:electron\"",
    "dev:electron": "npm run build:main && cross-env NODE_ENV=development wait-on http://localhost:3002 && electron .",
    "build": "npm run build:react && npm run build:electron",
    "build:main": "tsc -p tsconfig.json",
    "build:react": "webpack --mode production",
    "build:electron": "npm run build:main && electron-builder",
    "serve": "webpack serve --mode development"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.0.0",
    "html-webpack-plugin": "^5.6.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.1.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "dotenv": "^17.4.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sqlite3": "^6.0.1"
  }
}
